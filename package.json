{
  "name": "prompts34-social",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Instagram automation pipeline for Prompts34",
  "scripts": {
    "build": "tsc --noEmit",
    "generate": "tsx src/cli.ts generate",
    "publish": "tsx src/cli.ts publish",
    "publish:scheduled": "tsx src/cli.ts publish:scheduled",
    "instagram:validate": "tsx src/cli.ts instagram:validate",
    "twitter:authorize": "tsx src/cli.ts twitter:authorize",
    "twitter:validate": "tsx src/cli.ts twitter:validate",
    "generate:twitter": "tsx src/cli.ts generate:twitter",
    "publish:twitter": "tsx src/cli.ts publish:twitter",
    "publish:scheduled:twitter": "tsx src/cli.ts publish:scheduled:twitter",
    "test": "vitest run"
  },
  "dependencies": {
    "@google/genai": "^1.0.1",
    "@supabase/supabase-js": "^2.49.8",
    "dotenv": "^16.5.0",
    "sharp": "^0.34.5",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
